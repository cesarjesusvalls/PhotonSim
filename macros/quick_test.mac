# Quick PhotonSim smoke test — 5 mu- events at 1050 MeV with per-photon
# storage on and decays disabled. Useful as a "does PhotonSim still
# produce sensible output?" check after rebuilds. Edit the gun block
# below to swap particle / energy if you need a different probe.

# Set output filename before initialization
/output/filename quick_test.root

/run/initialize

# Enable individual photon storage to capture photon information
/photon/storeIndividual true

# Disable muon decay processes via macro commands
/particle/select mu-
/particle/process/inactivate 1
/particle/process/inactivate 7
/particle/select mu+
/particle/process/inactivate 1

# Set up primary particle with fixed energy
/gun/particle mu-
/gun/randomEnergy false
/gun/energy 1050 MeV
/gun/position 0 0 0 m
/gun/direction 0 0 1

# Run 5 events
/run/beamOn 5
